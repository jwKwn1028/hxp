# Sioyek user prefs. Tuned for use with `hxp` (markdown / tex / typst preview).
# See https://sioyek-documentation.readthedocs.io/ for the full reference.

# Reload the PDF on disk change. With this on, hxp's atomic mv just works
# (no need for SIGHUP, which sioyek doesn't honour).
auto_reload_preference 1

# Reverse search: Ctrl+click in the PDF jumps to source line in helix.
# `hxp-jump` reads the per-source state file hxp() writes in
# $XDG_RUNTIME_DIR/hxp and, if hxp was launched inside tmux, drives the
# existing helix pane via send-keys. Falls back to spawning a fresh `hx`
# when there's no live pane to talk to.
inverse_search_command hxp-jump %1:%2

# Always hand new files to the already-running sioyek window. Combined with
# `--reuse-window` on the command line this keeps hxp's edit-save loop in a
# single window instead of spawning a fresh one each invocation.
should_launch_new_window 0
should_launch_new_instance 0
