# Sioyek user prefs. Tuned for use with `hxp` (markdown / tex / typst preview).
# See https://sioyek-documentation.readthedocs.io/ for the full reference.

# Reload the PDF on disk change. With this on, hxp's atomic mv just works
# (no need for SIGHUP, which sioyek doesn't honour).
auto_reload_preference 1

# Reverse search: Ctrl+click in the PDF jumps to source line in helix.
# `hxp-jump` reads the per-source state file hxp() writes in
# $XDG_RUNTIME_DIR/hxp and, if hxp was launched inside tmux, drives the
# existing helix pane via send-keys. Falls back to spawning a fresh `hx`
# when there's no live pane to talk to.
inverse_search_command hxp-jump %1:%2

# Default to single-window/single-instance for stray launches (clicking a
# PDF in a file manager, etc.). hxp itself overrides this per-invocation
# with `--new-window` so concurrent sessions on different workspaces each
# get their own window inside the shared instance — otherwise the second
# hxp would silently hijack the first session's window.
should_launch_new_window 0
should_launch_new_instance 0

# sioyek-python-extensions: dual_panelify creates a side-by-side variant of
# the current PDF and opens it. The `sioyek` package is library-only (pipx
# rejects it), so it lives in a dedicated venv at
# ~/.local/share/sioyek-extensions and we invoke that venv's python directly.
new_command _dual_panelify /home/kjw1028/.local/share/sioyek-extensions/bin/python -m sioyek.dual_panelify "%{sioyek_path}" "%{file_path}" "%{command_text}"
