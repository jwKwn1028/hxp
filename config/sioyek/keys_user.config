# sioyek user keybindings. See /etc/sioyek/keys.config for defaults and
# https://sioyek-documentation.readthedocs.io/ for the full command list.

# ---------- sioyek-python-extensions ----------
# `d` triggers the _dual_panelify command defined in prefs_user.config,
# which spawns a side-by-side variant of the current PDF.
# _dual_panelify d

# ---------- Zathura-style aliases ----------
# Sioyek leans on the F-row (F8 dark mode, F9 fit-width, etc.); zathura
# users expect letter keys. These are added alongside the F-row bindings,
# only on keys that sioyek leaves unbound — existing defaults are untouched.

# F8 -> i: toggle inverted/dark colours (zathura "recolor")
toggle_dark_mode i

# F9 -> a: fit current page to window width (zathura "adjust to best-fit").
# Note: zathura's true "best fit" is `a`, page-width is `s`. `s` is taken
# by sioyek's external_search, so we map `a` to fit_to_page_width — close
# enough for the common case.
fit_to_page_width a

# Half-page scrolling, the zathura defaults
screen_down <C-d>
screen_up <C-u>

# Page stepping with Shift-J / Shift-K (zathura defaults). Lowercase j/k
# stay bound to move_visual_mark_down/up.
next_page J
previous_page K

# Top / bottom of current page (zathura H / L)
goto_top_of_page H
goto_bottom_of_page L

# Alternate goto-mark key (zathura uses `'`; sioyek's default is `` ` ``)
goto_mark '

# Reload current document (zathura <C-l>; sioyek uses auto_reload by default
# but exposes a manual `reload` command that's otherwise unbound)
reload <C-l>

# ---------- Inverse search ----------
# Hover the mouse over text, press F5 to jump to the source line in helix.
# One-shot — no need to toggle synctex mode with F4 first.
synctex_under_cursor <F5>
